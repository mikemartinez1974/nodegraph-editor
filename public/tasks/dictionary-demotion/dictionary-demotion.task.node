          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Risks\n\n- Breaking node class resolution while removing too much dictionary authority\n- Losing easy authoring workflows\n- Replacing one ambient system with another hidden one\n- Not having enough explicit graph structure to carry the new semantics",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
