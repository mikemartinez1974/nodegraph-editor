          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Capability Policy\n\n- Showing a node is not the same as running a node.\n- Static rendering can stay broad.\n- Live behavior, hooks, and side effects must eventually be scope-aware.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
