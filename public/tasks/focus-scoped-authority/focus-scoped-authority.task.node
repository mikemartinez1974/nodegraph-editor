          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Open Questions\n\n- What lifecycle events fire when focus enters or leaves a fragment?\n- Do scripts suspend, restart, or resume?\n- How should fragment-local history interact with document history?",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
      "id": "focus-auth-lifecycle",
      "type": "markdown",
      "label": "Lifecycle Defaults",
      "position": {
        "x": 1120,
        "y": 120
      },
      "width": 380,
      "height": 230,
      "color": "#2e7d32",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
            "side": "left",
            "offset": 0.5
          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Lifecycle Defaults\n\nStart with a small fragment lifecycle:\n- `fragmentMaterialize` on first load\n- `fragmentFocusEnter` when focus enters\n- `fragmentFocusLeave` when focus leaves\n- `fragmentReload` on local reload\n\nDefault behavior:\n- reload restarts scripts\n- if the focused node still exists after reload, restore focus to it\n- otherwise focus the fragment entry/root",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
