        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Graph-Native Relationship\n\nThe graph itself now carries the important semantics:\n- entry surfaces\n- bridges\n- expansion links\n- context boundaries\n- focus and provenance\n\nThat is where the power moved.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
      "id": "dict-demotion-plan",
      "type": "markdown",
      "label": "Work Ahead",
      "position": {
        "x": -160,
        "y": 280
      },
      "width": 360,
      "height": 210,
      "color": "#ef6c00",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
            "side": "left",
