      "data": {
        "markdown": "# Context Grammar Smoke\n\nThis graph tests two things:\n- `expand` can project a full graph document into the current host session\n- `bridge` can instantiate a node class locally without transferring authority\n\nUse the ports below and inspect the resulting graph state.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
