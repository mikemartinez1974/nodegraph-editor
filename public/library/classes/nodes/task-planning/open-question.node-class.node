    {
      "id": "open-question-editor-view",
      "type": "view",
      "label": "Editor View (editor.web)",
      "position": {
        "x": -760,
        "y": 20
      },
      "width": 380,
      "height": 230,
      "visible": true,
      "showLabel": true,
      "data": {
        "view": {
          "intent": "editor",
          "payload": "editor.web"
        },
        "editor": {
          "web": {
            "fields": [
              {
                "key": "label",
                "label": "Label",
                "type": "text",
                "path": "label",
                "placeholder": "Open Question"
              },
              {
                "key": "body",
                "label": "Question",
                "type": "markdown",
                "path": "data.body",
                "placeholder": "What is unresolved?",
                "multiline": true,
                "rows": 8
              },
              {
                "key": "status",
                "label": "Status",
                "type": "select",
                "path": "data.status",
                "options": [
                  {
                    "label": "Open",
                    "value": "open"
                  },
                  {
                    "label": "Investigating",
                    "value": "investigating"
                  },
                  {
                    "label": "Resolved",
                    "value": "resolved"
                  }
                ]
              },
              {
                "key": "owner",
                "label": "Owner",
                "type": "text",
                "path": "data.owner",
                "placeholder": "owner"
              },
              {
                "key": "resolutionPath",
                "label": "Resolution Path",
                "type": "text",
                "path": "data.resolutionPath",
                "placeholder": "nodeRef"
              },
              {
                "key": "prominence",
                "label": "Prominence",
                "type": "select",
                "path": "data.prominence",
                "options": [
                  {
                    "label": "High",
                    "value": "high"
                  },
                  {
                    "label": "Normal",
                    "value": "normal"
                  }
                ]
              }
            ]
          }
        }
      }
    },
    {
      "id": "open-question-detail-view",
