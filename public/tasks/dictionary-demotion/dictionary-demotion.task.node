          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Work Ahead\n\n1. Audit where dictionary authority is still assumed.\n2. Separate lookup/registration from authority.\n3. Move cross-context semantics into graph structure.\n4. Keep dictionary resolution as support, not sovereignty.\n5. Preserve node class robustness while reducing ambient power.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
      "id": "dict-demotion-risks",
      "type": "markdown",
      "label": "Risks",
      "position": {
        "x": 260,
        "y": 280
      },
      "width": 360,
      "height": 210,
      "color": "#6d4c41",
