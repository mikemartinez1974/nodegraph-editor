          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Avoid Baking In\n\n- Ambient global execution assumptions\n- Silent authority merging across visible graphs\n- Hooks firing everywhere because something is on screen\n- Node classes that cannot separate static render from live behavior",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
