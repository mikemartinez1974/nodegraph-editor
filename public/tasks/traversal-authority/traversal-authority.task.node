          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Traversal Policy\n\n- Fragment targets should feel like continuous traversal.\n- Non-fragment targets remain document boundaries.\n- Ring-based loading bounds growth.\n- Automatic expansion should follow graph type, not ad hoc guesses.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
      "id": "trav-authority",
      "type": "markdown",
      "label": "Authority Policy",
      "position": {
        "x": 320,
        "y": -40
      },
