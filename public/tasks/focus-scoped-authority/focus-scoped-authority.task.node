        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# History Default\n\nUse one shared document/session history for now.\n\n- Fragment reload is a normal history event in the shared node collection.\n- Story snapshots remain document-level milestones.\n- GitHub is the durable history system.\n- Do not add fragment-local history until there is a concrete need.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
