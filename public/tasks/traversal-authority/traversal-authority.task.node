          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Safe To Build Now\n\n- Graph type: `fragment` vs `graph`\n- Entry surfaces\n- Focus and fragment identity\n- Provenance metadata\n- Ring-based loading and semantic views\n\nThese preserve future scope cuts without breaking current behavior.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
