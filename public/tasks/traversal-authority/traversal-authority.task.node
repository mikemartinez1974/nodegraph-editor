          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Future Boundary\n\nDo not harden authority cutoffs prematurely. Keep the current theory working, but avoid deepening ambient power. Tight scope enforcement comes later when render and execution can be split cleanly.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
