          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Local Fragment Reload\n\n- Refresh should target the focused fragment source.\n- Rematerialize only nodes from that fragment.\n- Leave the rest of the visible graph intact.\n- Preserve layout anchors and attachment edges.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
