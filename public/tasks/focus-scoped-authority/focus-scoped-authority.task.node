    {
      "id": "focus-auth-overview",
      "type": "markdown",
      "label": "Focus Scoped Authority",
      "position": {
        "x": -620,
        "y": 0
      },
      "width": 430,
      "height": 230,
      "color": "#1976d2",
      "ports": [
        {
