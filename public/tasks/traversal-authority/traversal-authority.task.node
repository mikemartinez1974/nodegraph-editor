          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Authority Policy\n\n- Host authority remains primary inside fragment continuity.\n- Non-fragment navigation is where authority may transition.\n- The abstraction must match reality: if power is cut, it must actually be cut.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
