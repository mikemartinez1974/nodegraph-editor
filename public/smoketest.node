      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Root Graph Embed",
        "src": "/root.node",
        "mode": "interactive",
        "notes": "Switch mode to interactive to test pointer/event isolation behavior.",
        "endpoint": "/root.node"
      }
    },
    {
      "id": "graph-ref-smoke-checks",
      "type": "markdown",
      "label": "Expected Results",
      "position": {
        "x": 190,
        "y": 180
      },
      "width": 560,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Expected Results\n\n- Child graph uses its own manifest and dictionary.\n- Child graph state does not merge into parent graph namespace.\n- Multiple graph-reference nodes can coexist.\n- Existing non-reference nodes in parent still behave normally."
      }
    }
