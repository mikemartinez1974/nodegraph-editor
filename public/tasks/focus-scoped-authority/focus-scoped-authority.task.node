          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Fragment Provenance Contract\n\nEach loaded node needs:\n- fragment id\n- source ref\n- canonical local id\n- authority domain marker\n\nWithout provenance, focus-scoped authority cannot be enforced.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
    {
      "id": "focus-auth-remat",
      "type": "markdown",
      "label": "In-Place Rematerialization",
      "position": {
        "x": 320,
        "y": 280
      },
      "width": 360,
      "height": 210,
      "color": "#6d4c41",
      "ports": [
