      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Traversal And Authority\n\nTraversal, authority, and capability must be modeled together. The current system works, but future work must preserve the ability to cut scope cleanly later.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": true,
        "root": true
      }
    },
    {
      "id": "trav-traversal",
      "type": "markdown",
      "label": "Traversal Policy",
      "position": {
        "x": -120,
        "y": -40
      },
      "width": 360,
      "height": 210,
      "color": "#5e35b1",
      "ports": [
        {
