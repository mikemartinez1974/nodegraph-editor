      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# In-Place Rematerialization\n\nReloading a fragment means:\n- remove nodes for fragment F\n- fetch F\n- rematerialize F\n- reconnect attach edges\n- keep surrounding graph untouched",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false
      }
    },
